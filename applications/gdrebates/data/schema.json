            "target_id":          { "name": "target_id",          "type": "INT",      "length": 11,  "allow_null": false, "default": 0, "comment": "" },
            "manufacturer":       { "name": "manufacturer",       "type": "VARCHAR",  "length": 150, "allow_null": false, "default": "", "comment": "" },
            "scrape_url":         { "name": "scrape_url",         "type": "VARCHAR",  "length": 500, "allow_null": false, "default": "", "comment": "" },
            "run_at":             { "name": "run_at",             "type": "DATETIME",  "allow_null": true, "default": null, "comment": "" },
