            "status":             { "name": "status",             "type": "VARCHAR",  "length": 20,  "allow_null": false, "default": "success", "comment": "success|partial|failed|robots_blocked" },
            "error_log":          { "name": "error_log",          "type": "TEXT",      "allow_null": true, "default": null, "comment": "" }
