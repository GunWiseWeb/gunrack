            "idx_enabled":    { "type": "key",     "name": "idx_enabled",    "length": [ null ], "columns": [ "enabled" ] },
            "idx_mfr":        { "type": "key",     "name": "idx_mfr",        "length": [ null ], "columns": [ "manufacturer" ] }
        }
    },
    "gd_scrape_log": {
        "name": "gd_scrape_log",
